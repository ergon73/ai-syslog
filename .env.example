# Скопируйте в .env и заполните ОДИН из ключей.
# OpenRouter имеет приоритет, если заданы оба.
OPENROUTER_API_KEY=sk-or-...
#ANTHROPIC_API_KEY=sk-ant-...

# Модели (дефолты для OpenRouter — дешёвый триаж + сильный синтез):
#TRIAGE_MODEL=google/gemini-2.5-flash-lite
#SYNTHESIS_MODEL=openai/gpt-5-mini
# Дефолты для Anthropic: claude-haiku-4-5 / claude-opus-4-8

# Порты
SYSLOG_PORT=514
WEB_PORT=8514

# Анализировать сообщения severity <= N (4 = warning и хуже)
ANALYZE_SEVERITY_THRESHOLD=4
